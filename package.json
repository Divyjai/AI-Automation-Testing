{
  "name": "qa_automation",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:regression": "playwright test --grep @regression",
    "test:headed": "playwright test --headed",
    "test:report": "playwright show-report",
    "test:juicer": "playwright test tests/amazon-in/juicer --project=chromium --workers=1",
    "allure:prepare": "node scripts/allure-prepare.mjs",
    "allure:generate": "node scripts/allure-generate.mjs",
    "allure:open": "allure open allure-report",
    "allure:clean": "node -e \"const fs=require('fs');['allure-results','allure-report'].forEach(d=>fs.rmSync(d,{recursive:true,force:true}))\"",
    "allure:report": "npm run allure:generate && npm run allure:open",
    "test:allure": "playwright test --project=chromium --workers=1 && npm run allure:generate",
    "test:juicer:allure": "playwright test tests/amazon-in/juicer --project=chromium --workers=1 && npm run allure:generate",
    "test:professional": "playwright test tests/amazon-in/professional --project=chromium --workers=1",
    "test:professional:allure": "playwright test tests/amazon-in/professional --project=chromium --workers=1 && npm run allure:generate"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.2",
    "dotenv": "^16.6.1",
    "allure-playwright": "^3.2.1",
    "allure-commandline": "^2.34.0"
  }
}
