# Copy to .env and fill in values. Never commit .env to git.
# Load a different file: ENV_FILE=.env.staging npx playwright test

# Environment
TEST_ENV=local
BASE_URL=https://www.amazon.in

# Login credentials — required for authenticated test scenarios
# OTP is NOT stored here — you provide OTP in chat when pipeline asks
AMAZON_EMAIL=
AMAZON_PASSWORD=

# Test data overrides
DEFAULT_PINCODE=110001
SEARCH_TERM_VALID=books
SEARCH_TERM_PARTIAL=book
SEARCH_TERM_NO_RESULTS=xyznonexistentproduct12345
SEARCH_TERM_JUICER=juicer

# Playwright execution
HEADLESS=true
SLOW_MO=0
